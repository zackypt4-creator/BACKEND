Contoh UPDATE:

router.put("/api/quotes/:id", (req, res) => {

    const sql = "UPDATE quotes SET text=?, author=? WHERE id=?";

    db.query(
        sql,
        [req.body.text, req.body.author, req.params.id],
        (err, result) => {

            if (err) {
                return res.status(500).json({
                    success: false,
                    message: err.message
                });
            }

            res.json({
                success: true,
                message: "Quote berhasil diupdate"
            });

        }
    );

});


